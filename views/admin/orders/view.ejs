<h2 class="mb-4">Detail Pesanan #<%= order.order_number %></h2>

<div class="row mb-4">
    <div class="col-md-8">
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Informasi Pesanan</h5>
                <div class="row">
                    <div class="col-md-6">
                        <p><strong>No. Pesanan:</strong> <%= order.order_number %></p>
                        <p><strong>Tanggal:</strong> <%= new Date(order.created_at).toLocaleDateString('id-ID') %></p>
                        <p><strong>Status:</strong>
                            <span class="badge bg-<%= order.status === 'delivered' ? 'success' : order.status === 'processing' ? 'bg-warning' : order.status === 'shipped' ? 'bg-info' : 'secondary' %>">
                                <%= order.status.charAt(0).toUpperCase() + order.status.slice(1) %>
                            </span>
                        </p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Total:</strong> Rp <%= Number(order.total_amount).toLocaleString('id-ID', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></p>
                        <p><strong>Status Pembayaran:</strong>
                            <span class="badge bg-<%= order.payment_status === 'paid' ? 'success' : 'warning' %>">
                                <%= order.payment_status.charAt(0).toUpperCase() + order.payment_status.slice(1) %>
                            </span>
                        </p>
                    </div>
                </div>
                <% if (order.shipping_address) { %>
                    <div class="mt-3">
                        <h6>Alamat Pengiriman:</h6>
                        <p class="mb-0"><%= order.shipping_address %></p>
                    </div>
                <% } %>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Informasi Customer</h5>
                <p><strong>Nama:</strong> <%= order.user.name %></p>
                <p><strong>Email:</strong> <%= order.user.email %></p>
                <% if (order.user.phone) { %>
                    <p><strong>Telepon:</strong> <%= order.user.phone %></p>
                <% } %>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Item Pesanan</h5>
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Produk</th>
                                <th>Jumlah</th>
                                <th>Harga</th>
                                <th>Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% order.orderItems.forEach(item => { %>
                                <tr>
                                    <td><%= item.itemProduct.name %></td>
                                    <td><%= item.quantity %></td>
                                    <td>Rp <%= Number(item.price).toLocaleString('id-ID', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
                                    <td>Rp <%= (Number(item.price) * item.quantity).toLocaleString('id-ID', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Ringkasan</h5>
                <hr>
                <div class="d-flex justify-content-between mb-2">
                    <span>Subtotal:</span>
                    <span>Rp <%= Number(order.total_amount).toLocaleString('id-ID', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span>Ongkos Kirim:</span>
                    <span>Rp 0</span>
                </div>
                <hr>
                <div class="d-flex justify-content-between">
                    <strong>Total:</strong>
                    <strong class="text-danger">Rp <%= Number(order.total_amount).toLocaleString('id-ID', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></strong>
                </div>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-body">
                <h5 class="card-title">Update Status</h5>
                <form method="POST" action="/admin/orders/update-status/<%= order.id %>">
                    <div class="mb-3">
                        <label class="form-label fw-bold text-dark">Status Pesanan</label>
                        <select name="status" class="form-select form-select-lg" style="color: #000; background-color: #fff; border: 1px solid #dee2e6;">
                            <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %> style="color: #000;">Pending</option>
                            <option value="processing" <%= order.status === 'processing' ? 'selected' : '' %> style="color: #000;">Processing</option>
                            <option value="shipped" <%= order.status === 'shipped' ? 'selected' : '' %> style="color: #000;">Shipped</option>
                            <option value="delivered" <%= order.status === 'delivered' ? 'selected' : '' %> style="color: #000;">Delivered</option>
                            <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %> style="color: #000;">Cancelled</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 fw-bold">Update Status</button>
                </form>
            </div>
        </div>

        <style>
            .form-select {
                color: #000 !important;
                background-color: #fff !important;
            }
            .form-select option {
                color: #000 !important;
                background-color: #fff !important;
            }
            .form-label {
                color: #000 !important;
            }
        </style>

        <div class="card mt-3">
            <div class="card-body">
                <h6>Status Pengiriman</h6>
                <div class="progress mt-2">
                    <div class="progress-bar <%= order.status === 'delivered' ? 'bg-success' : order.status === 'shipped' ? 'bg-info' : order.status === 'processing' ? 'bg-warning' : 'bg-secondary' %>"
                         style="width: <%= order.status === 'delivered' ? '100' : order.status === 'shipped' ? '75' : order.status === 'processing' ? '50' : '25' %>%">
                    </div>
                </div>
                <small class="text-muted mt-1 d-block">
                    <%= order.status === 'delivered' ? 'Pesanan telah diterima' :
                       order.status === 'shipped' ? 'Pesanan sedang dikirim' :
                       order.status === 'processing' ? 'Pesanan sedang diproses' : 'Pesanan diterima' %>
                </small>
            </div>
        </div>
    </div>
</div>