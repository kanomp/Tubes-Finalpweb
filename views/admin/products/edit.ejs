<div class="container mt-5">
  <div class="row">
    <div class="col-md-8">
      <div class="card">
        <div class="card-body">
          <h2 class="card-title mb-4">Edit Product</h2>
          
          <form method="POST" action="/admin/products/update/<%= product.id %>" enctype="multipart/form-data">
            <div class="mb-3">
              <label class="form-label fw-bold">Product Name</label>
              <input type="text" name="name" class="form-control" value="<%= product.name %>" required>
            </div>

            <div class="mb-3">
              <label class="form-label fw-bold">Description</label>
              <textarea name="description" class="form-control" rows="4"><%= product.description || '' %></textarea>
            </div>

            <div class="row">
              <div class="col-md-6">
                <div class="mb-3">
                  <label class="form-label fw-bold">Price (Rp)</label>
                  <input type="number" name="price" class="form-control" value="<%= product.price %>" required step="0.01">
                </div>
              </div>
              <div class="col-md-6">
                <div class="mb-3">
                  <label class="form-label fw-bold">Stock</label>
                  <input type="number" name="stock" class="form-control" value="<%= product.stock %>" required step="1">
                </div>
              </div>
            </div>

            <div class="mb-3">
              <label class="form-label fw-bold">Category ID</label>
              <input type="number" name="category_id" class="form-control" value="<%= product.category_id %>" required>
            </div>

            <div class="mb-3">
              <label class="form-label fw-bold">Product Image</label>
              <% if (product.image) { %>
                <div class="mb-2">
                  <img src="/images/Produk/<%= product.image %>" alt="<%= product.name %>" style="max-width: 150px; height: auto;">
                </div>
              <% } %>
              <input type="file" name="image" class="form-control" accept="image/*">
              <small class="text-muted">Leave empty to keep current image. Accepted formats: JPEG, JPG, PNG, GIF.</small>
            </div>

            <div class="d-flex gap-2">
              <button type="submit" class="btn btn-primary fw-bold">Save Changes</button>
              <a href="/admin/products/view/<%= product.id %>" class="btn btn-secondary fw-bold">Cancel</a>
              <a href="/admin/products" class="btn btn-outline-secondary fw-bold">Back to Products</a>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card bg-light">
        <div class="card-body">
          <h5 class="card-title">Current Product Info</h5>
          <hr>
          <p class="mb-2"><strong>ID:</strong> <%= product.id %></p>
          <p class="mb-2"><strong>Name:</strong> <%= product.name %></p>
          <p class="mb-2"><strong>Price:</strong> Rp <%= Number(product.price).toLocaleString('id-ID', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></p>
          <p class="mb-2"><strong>Stock:</strong> <%= product.stock %></p>
          <p class="mb-2"><strong>Category:</strong> <%= product.category_id %></p>
          <hr>
          <p><strong>Created:</strong><br><small><%= new Date(product.created_at).toLocaleString('id-ID') %></small></p>
        </div>
      </div>
    </div>
  </div>
</div>

