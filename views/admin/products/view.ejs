<div class="container mt-5">
  <div class="row">
    <div class="col-md-8">
      <div class="card mb-3">
        <div class="card-body">
          <h2 class="card-title mb-4"><%= product.name %></h2>
          
          <div class="row mb-3">
            <div class="col-md-6">
              <p><strong>ID:</strong> <%= product.id %></p>
              <p><strong>Category ID:</strong> <%= product.category_id %></p>
              <p><strong>Price:</strong> <span class="text-danger fw-bold">Rp <%= Number(product.price).toLocaleString('id-ID', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></span></p>
            </div>
            <div class="col-md-6">
              <p><strong>Stock:</strong> <span class="badge bg-info"><%= product.stock %></span></p>
              <p><strong>Created:</strong> <%= new Date(product.created_at).toLocaleDateString('id-ID') %></p>
            </div>
          </div>

          <div class="mt-4">
            <h5>Description</h5>
            <p class="description-text" style="white-space: pre-line;"><%= product.description || 'No description provided' %></p>
          </div>
        </div>
      </div>

      <div class="d-flex gap-2">
        <a href="/admin/products/edit/<%= product.id %>" class="btn btn-warning fw-bold">Edit Product</a>
        <a href="/admin/products" class="btn btn-secondary fw-bold">Back to Products</a>
        <form method="POST" action="/admin/products/delete/<%= product.id %>" style="display:inline;">
          <button type="submit" class="btn btn-danger fw-bold" onclick="return confirm('Are you sure you want to delete this product?')">Delete Product</button>
        </form>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card">
        <div class="card-body">
          <h5 class="card-title">Product Info</h5>
          <hr>
          <p class="mb-2"><strong>SKU:</strong> <%= product.sku || 'N/A' %></p>
          <p class="mb-2"><strong>Category:</strong> <%= product.category_id %></p>
          <p class="mb-2"><strong>Status:</strong> <span class="badge bg-success">Active</span></p>
          <hr>
          <p><strong>Created At:</strong><br><small><%= new Date(product.created_at).toLocaleString('id-ID') %></small></p>
        </div>
      </div>
    </div>
  </div>
</div>
