<div class="container mt-5">
  <div class="row">
    <div class="col-md-8">
      <div class="card">
        <div class="card-body">
          <h2 class="card-title mb-4">Edit User</h2>
          <form method="POST" action="/admin/users/update/<%= managedUser.id %>">
            <div class="mb-3">
              <label class="form-label fw-bold">Name</label>
              <input type="text" name="name" class="form-control" value="<%= managedUser.name %>" required>
            </div>
            <div class="mb-3">
              <label class="form-label fw-bold">Email</label>
              <input type="email" name="email" class="form-control" value="<%= managedUser.email %>" required>
            </div>
            <div class="mb-3">
              <label class="form-label fw-bold">Password</label>
              <input type="password" name="password" class="form-control" placeholder="Kosongkan jika tidak ingin mengganti password">
              <small class="text-muted">Biarkan kosong jika tidak ingin mengubah password.</small>
            </div>
            <div class="mb-3">
              <label class="form-label fw-bold">Phone</label>
              <input type="text" name="phone" class="form-control" value="<%= managedUser.phone || '' %>">
            </div>
            <div class="mb-3">
              <label class="form-label fw-bold">Address</label>
              <textarea name="address" class="form-control" rows="3"><%= managedUser.address || '' %></textarea>
            </div>
            <div class="mb-3">
              <label class="form-label fw-bold text-dark">Role</label>
              <select name="role" class="form-select form-select-lg" style="color: #000; background-color: #fff; border: 1px solid #dee2e6;">
                <option value="customer" <%= managedUser.role === 'customer' ? 'selected' : '' %> style="color: #000;">User</option>
                <option value="admin" <%= managedUser.role === 'admin' ? 'selected' : '' %> style="color: #000;">Admin</option>
              </select>
            </div>
            <div class="d-flex gap-2">
              <button type="submit" class="btn btn-primary fw-bold">Save Changes</button>
              <a href="/admin/users/view/<%= managedUser.id %>" class="btn btn-secondary fw-bold">Cancel</a>
              <a href="/admin/users" class="btn btn-outline-secondary fw-bold">Back to Users</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .form-select {
    color: #000 !important;
    background-color: #fff !important;
  }
  .form-select option {
    color: #000 !important;
    background-color: #fff !important;
  }
  .form-label {
    color: #000 !important;
  }
</style>
