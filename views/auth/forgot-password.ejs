<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h3 class="card-title text-center mb-4">Lupa Password</h3>

                <% if (typeof error !== 'undefined') { %>
                    <div class="alert alert-danger">
                        <%= error %>
                    </div>
                <% } %>

                <% if (typeof success !== 'undefined') { %>
                    <div class="alert alert-success">
                        <%= success %>
                        <br>
                        <a href="/auth/verify-otp?email=<%= email %>">Verifikasi OTP</a>
                    </div>
                <% } %>

                <form method="POST" id="forgotForm">
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="email" class="form-control" required>
                    </div>
                    <input type="hidden" name="otp" id="otpInput">

                    <button type="submit" class="btn btn-primary w-100">Kirim OTP</button>
                </form>

                <hr>

                <p class="text-center">
                    <a href="/auth/login">Kembali ke Login</a>
                </p>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/emailjs-com@3/dist/email.min.js"></script>
<script>
(function(){
  emailjs.init("3STkpUfcKNreSddqN");
})();

document.getElementById('forgotForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const email = this.email.value;

    // Generate OTP (4 digits)
    const otp = Math.floor(1000 + Math.random() * 9000).toString();
    document.getElementById('otpInput').value = otp;

    // Send OTP via EmailJS
   emailjs.send("service_27ls3oz", "template_415otz7", {
    to_email: email,
    otp: otp
})
    .then(function(response) {
        console.log("SUCCESS", response);
        // After email is sent, submit form to server so OTP is saved in database
        document.getElementById('forgotForm').submit();
    })
    .catch(function(error) {
        console.log("ERROR DETAIL:", error);
        alert("Gagal kirim OTP. Coba lagi.");
    });
});
</script>