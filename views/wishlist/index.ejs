<h2 class="mb-4">Wishlist Saya</h2>

<% if (wishlistItems.length === 0) { %>
    <div class="alert alert-info">
        Wishlist Anda kosong. <a href="/">Jelajahi produk</a>
    </div>
<% } else { %>
    <div class="row">
        <% wishlistItems.forEach(item => { %>
            <div class="col-md-4 mb-4">
                <div class="card product-card h-100">
                    <div class="bg-light" style="height: 200px; overflow: hidden;">
                        <img src="<%= item.wishProduct.category_id === 1 ? '/images/Produk/Senjata/' : '/images/Produk/' %><%= item.wishProduct.image || 'placeholder.jpg' %>"
                             class="card-img-top product-image" alt="<%= item.wishProduct.name %>">
                    </div>
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">
                            <a href="/product/<%= item.wishProduct.slug %>" class="text-decoration-none text-white">
                                <%= item.wishProduct.name %>
                            </a>
                        </h5>
                        <p class="product-price text-danger fw-bold">Rp <%= Number(item.wishProduct.price).toLocaleString('id-ID', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></p>
                        <p class="product-stock">Stok: <%= item.wishProduct.stock %></p>
                        <div class="mt-auto">
                            <form method="POST" action="/cart/add" class="d-inline">
                                <input type="hidden" name="product_id" value="<%= item.wishProduct.id %>">
                                <button type="submit" class="btn btn-primary btn-sm">Tambahkan ke Keranjang</button>
                            </form>
                            <form method="POST" action="/wishlist/remove/<%= item.wishProduct.id %>" class="d-inline">
                                <button type="submit" class="btn btn-danger btn-sm"
                                        onclick="return confirm('Hapus dari wishlist?')">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
<% } %>